# Local-only scripts
scripts/sync-from-production.mjs

# Local Netlify folder
.netlify

# Design handoff bundles (gzipped tarballs, not source)
cache/

# Generated concepts-worksheet tool (rebuild via scripts/build-concepts-tool.py
# --build-html; ~1.1 MB artifact). The README + template + parser are tracked;
# the built HTML is not.
docs/plans/concepts-worksheet-form/concepts-worksheet-tool.html

# Stage 2 re-tag artifacts (corpus exports, run outputs, sidecar bodies) —
# generated by scripts/stage2-retag/*; never committed
scripts/stage2-retag/artifacts/
